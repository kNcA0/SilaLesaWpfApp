<Window x:Class="SilaLesaWpfApp.ModeratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модератор — Сила леса"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="10" LastChildFill="False">
            <TextBlock x:Name="tbHeader" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Обновить" Width="90" Margin="0,0,10,0" Click="BtnRefresh_Click"/>
                <Button Content="Выйти" Width="90" Click="BtnLogout_Click"/>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Клиенты">
                <DataGrid x:Name="dgCustomers" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True" Margin="10"/>
            </TabItem>

            <TabItem Header="Места">
                <DataGrid x:Name="dgSites" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True" Margin="10"/>
            </TabItem>

            <TabItem Header="Услуги">
                <DataGrid x:Name="dgServices" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True" Margin="10"/>
            </TabItem>

            <TabItem Header="Бронирования">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgBookings" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True" SelectionMode="Single"/>

                    <GroupBox Grid.Row="1" Header="Изменить статус (без доступа к пользователям/ролям)" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Статус:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbBookingStatus" Width="140" Margin="5,0,10,0">
                                <ComboBoxItem Content="Забронировано" Tag="Booked"/>
                                <ComboBoxItem Content="Завершено" Tag="Completed"/>
                                <ComboBoxItem Content="Отменено" Tag="Cancelled"/>
                            </ComboBox>
                            <Button Content="Применить" Width="90" Click="BtnUpdateBookingStatus_Click"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
