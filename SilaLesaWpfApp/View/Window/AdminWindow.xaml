<Window x:Class="SilaLesaWpfApp.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администратор — Сила леса"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="10" LastChildFill="False">
            <TextBlock x:Name="tbHeader" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Обновить всё" Width="110" Margin="0,0,10,0" Click="BtnRefreshAll_Click"/>
                <Button Content="Выйти" Width="90" Click="BtnLogout_Click"/>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1" Margin="10">
            <!-- USERS & ROLES -->
            <TabItem Header="Пользователи и роли">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Добавить роль" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Название роли:" Width="105" VerticalAlignment="Center"/>
                            <TextBox x:Name="tbNewRole" Width="220" Margin="0,0,10,0"/>
                            <Button Content="Добавить роль" Width="130" Click="BtnAddRole_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Роли" Margin="0,0,10,0">
                            <DataGrid x:Name="dgRoles" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True"/>
                        </GroupBox>

                        <GroupBox Header="Пользователи" Grid.Column="1">
                            <DataGrid x:Name="dgUsers" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True" SelectionMode="Single"/>
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="Добавить пользователя" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Логин" VerticalAlignment="Center"/>
                            <TextBox x:Name="tbNewUser" Width="140" Margin="5,0,10,0"/>

                            <TextBlock Text="Пароль" VerticalAlignment="Center"/>
                            <TextBox x:Name="tbNewPass" Width="140" Margin="5,0,10,0"/>

                            <TextBlock Text="Роль" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbNewUserRole" Width="140" Margin="5,0,10,0"/>

                            <Button Content="Добавить" Width="90" Click="BtnAddUser_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="3" Header="Действия с выбранным пользователем" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Новая роль" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbChangeRole" Width="140" Margin="5,0,10,0"/>
                            <Button Content="Сменить роль" Width="115" Margin="0,0,10,0" Click="BtnChangeRole_Click"/>

                            <Button Content="Переключить активность" Width="115" Click="BtnToggleActive_Click"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- CUSTOMERS -->
            <TabItem Header="Клиенты">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="90" Click="BtnRefreshCustomers_Click"/>

                        <TextBlock Text="   Добавить:" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <TextBox x:Name="tbCustName" Width="180" Margin="5,0,0,0" ToolTip="ФИО"/>
                        <TextBox x:Name="tbCustPhone" Width="120" Margin="5,0,0,0" ToolTip="Телефон"/>
                        <TextBox x:Name="tbCustEmail" Width="180" Margin="5,0,0,0" ToolTip="Эл. почта"/>
                        <Button Content="Добавить клиента" Width="110" Margin="5,0,0,0" Click="BtnAddCustomer_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgCustomers" Grid.Row="1" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <!-- SITES -->
            <TabItem Header="Места">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="90" Click="BtnRefreshSites_Click"/>

                        <TextBlock Text="   Добавить:" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <TextBox x:Name="tbSiteCode" Width="80" Margin="5,0,0,0" ToolTip="Код"/>
                        <TextBox x:Name="tbSiteName" Width="160" Margin="5,0,0,0" ToolTip="Название"/>
                        <TextBox x:Name="tbSiteType" Width="90" Margin="5,0,0,0" ToolTip="Палатка/Кемпер/Домик/Глэмпинг"/>
                        <TextBox x:Name="tbSiteCap" Width="60" Margin="5,0,0,0" ToolTip="Вместимость"/>
                        <TextBox x:Name="tbSitePrice" Width="80" Margin="5,0,0,0" ToolTip="Цена за ночь"/>
                        <Button Content="Добавить место" Width="90" Margin="5,0,0,0" Click="BtnAddSite_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgSites" Grid.Row="1" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <!-- SERVICES -->
            <TabItem Header="Услуги">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="90" Click="BtnRefreshServices_Click"/>

                        <TextBlock Text="   Добавить:" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <TextBox x:Name="tbSvcName" Width="170" Margin="5,0,0,0" ToolTip="Название услуги"/>
                        <TextBox x:Name="tbSvcType" Width="90" Margin="5,0,0,0" ToolTip="Оборудование/Транспорт/Другое"/>
                        <TextBox x:Name="tbSvcPrice" Width="80" Margin="5,0,0,0" ToolTip="Цена за день"/>
                        <Button Content="Добавить услугу" Width="100" Margin="5,0,0,0" Click="BtnAddService_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgServices" Grid.Row="1" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <!-- BOOKINGS -->
            <TabItem Header="Бронирования">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Обновить" Width="90" Click="BtnRefreshBookings_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgBookings" Grid.Row="1" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True" SelectionMode="Single"/>

                    <GroupBox Grid.Row="2" Header="Изменить статус выбранного бронирования" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Статус:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbBookingStatus" Width="140" Margin="5,0,10,0">
                                <ComboBoxItem Content="Забронировано" Tag="Booked"/>
                                <ComboBoxItem Content="Завершено" Tag="Completed"/>
                                <ComboBoxItem Content="Отменено" Tag="Cancelled"/>
                            </ComboBox>
                            <Button Content="Применить" Width="90" Click="BtnUpdateBookingStatus_Click"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- VISITS -->
            <TabItem Header="Посещения">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="Обновить" Width="90" Click="BtnRefreshVisits_Click"/>
                    <DataGrid x:Name="dgVisits" Grid.Row="1" AutoGenerateColumns="True" AutoGeneratingColumn="DataGrid_AutoGeneratingColumn" IsReadOnly="True" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
